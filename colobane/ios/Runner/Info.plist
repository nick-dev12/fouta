		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<!-- Google Sign-In (iOS) -->
		<key>GIDClientID</key>
		<string>983006440407-0lj1ljivl26pt6emhu4tlvgl2p047rgp.apps.googleusercontent.com</string>
		<key>GIDServerClientID</key>
		<string>983006440407-goai5vsnrtaur5fpk8vq8m6gdnv1eh90.apps.googleusercontent.com</string>
		<!-- URL schemes : reversed client ID (Google) + scheme app -->
		<key>CFBundleURLTypes</key>
		<array>
			<dict>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>com.googleusercontent.apps.983006440407-0lj1ljivl26pt6emhu4tlvgl2p047rgp</string>
				</array>
			</dict>
		</array>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<!-- Chaînes d'objectif (Guideline Apple 5.1.1) — usage réel + exemple concret -->
		<key>NSCameraUsageDescription</key>
		<string>COLObanes utilise l'appareil photo lorsque vous appuyez sur « Prendre une photo » pour illustrer votre profil, une fiche produit vendeur ou joindre une image à un message (par exemple : photographier un article que vous mettez en vente sur la marketplace).</string>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>COLObanes accède à vos photos uniquement si vous choisissez « Importer depuis la galerie » pour ajouter une image à votre profil, à une boutique ou à un produit (par exemple : sélectionner une photo existante comme photo de profil).</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>COLObanes peut enregistrer dans votre photothèque une image que vous téléchargez depuis la plateforme, uniquement lorsque vous utilisez explicitement la fonction d'enregistrement proposée à l'écran.</string>
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>COLObanes utilise votre position lorsque vous demandez la localisation pour préremplir ou confirmer votre adresse de livraison sur la carte (par exemple : afficher le point de livraison lors du passage d'une commande au Sénégal).</string>
		<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
		<string>COLObanes accède à votre position uniquement lorsque vous utilisez la fonction de localisation pour préremplir ou confirmer une adresse de livraison sur la carte. L'app ne suit pas votre position en arrière-plan.</string>
		<!-- Production : HTTPS uniquement (développement local possible via exceptions ciblées si besoin) -->
		<key>NSAppTransportSecurity</key>
		<dict>
			<key>NSAllowsArbitraryLoads</key>
			<false/>
		</dict>
		<key>UIStatusBarHidden</key>
		<false/>
		<key>FirebaseAppDelegateProxyEnabled</key>
		<false/>
		<!-- Notifications push (APNs / FCM) -->
		<key>UIBackgroundModes</key>
		<array>
			<string>remote-notification</string>
		</array>
	</dict>
</plist>
